<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="FreshEstimate.Mobile.Views.LineItemTemplatesPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:viewmodels="clr-namespace:FreshEstimate.Mobile.ViewModels"
    xmlns:models="clr-namespace:FreshEstimate.Mobile.Models"
    x:DataType="viewmodels:LineItemTemplatesViewModel"
    Title="Templates"
    BackgroundColor="#F4F7FB">

    <Grid Padding="16" RowDefinitions="Auto,*,Auto" RowSpacing="12">
        <HorizontalStackLayout Spacing="8">
            <Button Text="Add Template" Command="{Binding AddTemplateCommand}" />
            <Button Text="Save Changes" Command="{Binding SaveTemplateCommand}" />
            <Button Text="Delete" Command="{Binding DeleteTemplateCommand}" BackgroundColor="#9B1C1C" />
        </HorizontalStackLayout>

        <CollectionView Grid.Row="1"
                        ItemsSource="{Binding Templates}"
                        SelectedItem="{Binding SelectedTemplate, Mode=TwoWay}"
                        SelectionMode="Single">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:LineItemTemplate">
                    <Border BackgroundColor="White"
                            Stroke="#E5E7EB"
                            StrokeThickness="1"
                            Padding="14"
                            Margin="0,0,0,10">
                        <VerticalStackLayout>
                            <Label Text="{Binding Name}"
                                   FontAttributes="Bold"
                                   FontSize="18"
                                   TextColor="#112033" />
                            <Label Text="{Binding Description}"
                                   TextColor="#667085" />
                        </VerticalStackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Border Grid.Row="2"
                BackgroundColor="White"
                Stroke="#E5E7EB"
                StrokeThickness="1"
                Padding="14">
            <VerticalStackLayout Spacing="10">
                <Label Text="Selected Template"
                       FontAttributes="Bold"
                       FontSize="20"
                       TextColor="#112033" />

                <Entry Placeholder="Template Name"
                       Text="{Binding EditName}" />

                <Entry Placeholder="Description"
                       Text="{Binding EditDescription}" />

                <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8">
                    <Entry Placeholder="Qty"
                           Text="{Binding EditDefaultQuantity}"
                           Keyboard="Numeric" />
                    <Entry Grid.Column="1"
                           Placeholder="Unit Price"
                           Text="{Binding EditDefaultUnitPrice}"
                           Keyboard="Numeric" />
                    <Entry Grid.Column="2"
                           Placeholder="Tax %"
                           Text="{Binding EditDefaultTaxRatePercent}"
                           Keyboard="Numeric" />
                </Grid>
            </VerticalStackLayout>
        </Border>
    </Grid>
</ContentPage>