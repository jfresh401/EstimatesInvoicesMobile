<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="FreshEstimate.Mobile.Views.LineItemTemplatesPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:viewmodels="clr-namespace:FreshEstimate.Mobile.ViewModels"
    xmlns:models="clr-namespace:FreshEstimate.Mobile.Models"
    x:DataType="viewmodels:LineItemTemplatesViewModel"
    Title="Templates"
    BackgroundColor="#F4F7FB">

    <Grid Padding="16" RowDefinitions="Auto,*,Auto" RowSpacing="12">
        <HorizontalStackLayout Spacing="8">
            <Button Text="Add Template" Command="{Binding AddTemplateCommand}" />
            <Button Text="Save Changes" Command="{Binding SaveTemplateCommand}" />
            <Button Text="Delete" Command="{Binding DeleteTemplateCommand}" BackgroundColor="#9B1C1C" />
        </HorizontalStackLayout>

        <CollectionView Grid.Row="1"
                ItemsSource="{Binding Templates}"
                SelectedItem="{Binding SelectedTemplate, Mode=TwoWay}"
                SelectionMode="Single">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:LineItemTemplate">
                    <Border BackgroundColor="White"
                    Stroke="#E5E7EB"
                    StrokeThickness="1"
                    Padding="14"
                    Margin="0,0,0,10">
                        <VerticalStackLayout>
                            <Label Text="{Binding Name}"
                           FontAttributes="Bold"
                           FontSize="18"
                           TextColor="#112033" />
                            <Label Text="{Binding Description}"
                           TextColor="#667085" />
                        </VerticalStackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Border Grid.Row="2"
        BackgroundColor="White"
        Stroke="#E5E7EB"
        StrokeThickness="1"
        Padding="14">
            <VerticalStackLayout Spacing="10">
                <Label Text="Selected Template"
               FontAttributes="Bold"
               FontSize="20"
               TextColor="#112033" />

                <Label Text="Name"
               FontAttributes="Bold"
               FontSize="12"
               TextColor="#112033" />
                <Entry Placeholder="Template Name"
               Text="{Binding EditName}" />

                <Label Text="Description"
               FontAttributes="Bold"
               FontSize="12"
               TextColor="#112033" />
                <Entry Placeholder="Description"
               Text="{Binding EditDescription}" />

                <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Qty"
                       FontAttributes="Bold"
                       FontSize="12"
                       TextColor="#112033" />
                        <Entry Placeholder="Qty"
                       Text="{Binding EditDefaultQuantity}"
                       Keyboard="Numeric" />
                    </VerticalStackLayout>

                    <VerticalStackLayout Grid.Column="1" Spacing="4">
                        <Label Text="Price"
                       FontAttributes="Bold"
                       FontSize="12"
                       TextColor="#112033" />
                        <Entry Placeholder="Price"
                       Text="{Binding EditDefaultUnitPrice}"
                       Keyboard="Numeric" />
                    </VerticalStackLayout>

                    <VerticalStackLayout Grid.Column="2" Spacing="4">
                        <Label Text="Tax %"
                       FontAttributes="Bold"
                       FontSize="12"
                       TextColor="#112033" />
                        <Entry Placeholder="Tax %"
                       Text="{Binding EditDefaultTaxRatePercent}"
                       Keyboard="Numeric" />
                    </VerticalStackLayout>
                </Grid>
            </VerticalStackLayout>
        </Border>
    </Grid>
</ContentPage>