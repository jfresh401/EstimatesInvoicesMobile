<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="FreshEstimate.Mobile.Views.DashboardPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:viewmodels="clr-namespace:FreshEstimate.Mobile.ViewModels"
    xmlns:models="clr-namespace:FreshEstimate.Mobile.Models"
    xmlns:conv="clr-namespace:FreshEstimate.Mobile.Converters"
    x:DataType="viewmodels:DashboardViewModel"
    Title="Dashboard"
    BackgroundColor="#F4F7FB">

    <ContentPage.Resources>
        <conv:CurrencyConverter x:Key="CurrencyConverter" />
    </ContentPage.Resources>

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="14">
            <Label Text="Fresh Estimate and Invoicing"
                   FontSize="24"
                   FontAttributes="Bold"
                   TextColor="#112033" />

            <Grid ColumnDefinitions="*,*"
                  RowDefinitions="Auto,Auto,Auto"
                  ColumnSpacing="12"
                  RowSpacing="12">

                <Border BackgroundColor="White" Stroke="#E5E7EB" StrokeThickness="1" Padding="14">
                    <VerticalStackLayout>
                        <Label Text="Customers" TextColor="#667085" />
                        <Label Text="{Binding TotalCustomers}" FontSize="28" FontAttributes="Bold" TextColor="#112033" />
                    </VerticalStackLayout>
                </Border>

                <Border Grid.Column="1" BackgroundColor="White" Stroke="#E5E7EB" StrokeThickness="1" Padding="14">
                    <VerticalStackLayout>
                        <Label Text="Documents" TextColor="#667085" />
                        <Label Text="{Binding TotalDocuments}" FontSize="28" FontAttributes="Bold" TextColor="#112033" />
                    </VerticalStackLayout>
                </Border>

                <Border Grid.Row="1" BackgroundColor="White" Stroke="#E5E7EB" StrokeThickness="1" Padding="14">
                    <VerticalStackLayout>
                        <Label Text="Outstanding" TextColor="#667085" />
                        <Label Text="{Binding OutstandingRevenue, Converter={StaticResource CurrencyConverter}}" FontSize="22" FontAttributes="Bold" TextColor="#112033" />
                    </VerticalStackLayout>
                </Border>

                <Border Grid.Row="1" Grid.Column="1" BackgroundColor="White" Stroke="#E5E7EB" StrokeThickness="1" Padding="14">
                    <VerticalStackLayout>
                        <Label Text="Paid Revenue" TextColor="#667085" />
                        <Label Text="{Binding PaidRevenue, Converter={StaticResource CurrencyConverter}}" FontSize="22" FontAttributes="Bold" TextColor="#112033" />
                    </VerticalStackLayout>
                </Border>

                <Border Grid.Row="2" BackgroundColor="White" Stroke="#E5E7EB" StrokeThickness="1" Padding="14">
                    <VerticalStackLayout>
                        <Label Text="Estimate Pipeline" TextColor="#667085" />
                        <Label Text="{Binding EstimatePipeline, Converter={StaticResource CurrencyConverter}}" FontSize="22" FontAttributes="Bold" TextColor="#112033" />
                    </VerticalStackLayout>
                </Border>

                <Border Grid.Row="2" Grid.Column="1" BackgroundColor="White" Stroke="#E5E7EB" StrokeThickness="1" Padding="14">
                    <VerticalStackLayout>
                        <Label Text="Overdue Invoices" TextColor="#667085" />
                        <Label Text="{Binding OverdueCount}" FontSize="28" FontAttributes="Bold" TextColor="#112033" />
                    </VerticalStackLayout>
                </Border>
            </Grid>

            <Label Text="Recent Documents"
                   Margin="0,8,0,0"
                   FontSize="22"
                   FontAttributes="Bold"
                   TextColor="#112033" />

            <CollectionView ItemsSource="{Binding RecentDocuments}">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:BusinessDocument">
                        <Border BackgroundColor="White"
                                Stroke="#E5E7EB"
                                StrokeThickness="1"
                                Padding="14"
                                Margin="0,0,0,10">
                            <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto">
                                <Label Text="{Binding Number}" FontSize="18" FontAttributes="Bold" TextColor="#112033" />
                                <Label Grid.Column="1"
                                       Text="{Binding GrandTotal, Converter={StaticResource CurrencyConverter}}"
                                       FontAttributes="Bold"
                                       TextColor="#112033" />
                                <Label Grid.Row="1" Text="{Binding Title}" TextColor="#112033" />
                                <Label Grid.Row="2" Text="{Binding Customer.DisplayName}" TextColor="#667085" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>